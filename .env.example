# ForgeCode model configuration
# Copy this file to .env, then replace the placeholder values.
# Never commit your real .env file.

# API Key (required)
# Anthropic keys: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key

# Model ID (required)
MODEL_ID=claude-sonnet-4-6

# Maximum output tokens for one model request (optional, 1024-32768)
MODEL_MAX_TOKENS=8192

# Base URL (optional)
# Remove this line to use the official Anthropic API.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
# Anthropic-compatible provider examples
# Verify current model availability, pricing, and regional access in the
# provider's official documentation before use.
# =============================================================================

# Anthropic
# MODEL_ID=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# MiniMax international
# MODEL_ID=MiniMax-M2.7
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# MiniMax China mainland
# MODEL_ID=MiniMax-M2.7
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# GLM (Zhipu)
# MODEL_ID=glm-5.2
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# DeepSeek
# MODEL_ID=deepseek-v4-flash
# MODEL_ID=deepseek-v4-pro
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Kimi Code membership uses a separate key and server-side model routing.
# Check Kimi Code documentation before use.
# ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
